---
import '../styles/theme.css';
import '../styles/layout.css';
import '../styles/sidebar-nav.css';
import '../styles/logout-button.css';
import '../styles/auth-guard.css';
import '../styles/no-permission.css';
import '../styles/theme-toggle.css';
import '../styles/sidebar-toggle.css';
import SidebarNav from '../components/SidebarNav.vue';
import LogoutButton from '../components/LogoutButton.vue';
import AuthGuard from '../components/AuthGuard.vue';
import ThemeToggle from '../components/ThemeToggle.vue';
import SidebarToggle from '../components/SidebarToggle.vue';
import SidebarOverlay from '../components/SidebarOverlay.vue';

interface Props {
  title?: string;
}

const { title = 'Stats Dashboard' } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <AuthGuard client:load>
      <div class="layout">
        <aside class="layout__sidebar">
          <div class="layout__logo">
            <span class="layout__logo-text">Stats</span>
          </div>
          <SidebarNav client:load />
          <LogoutButton client:load />
        </aside>
        <SidebarOverlay client:load />
        <main class="layout__main">
          <header class="layout__header">
            <SidebarToggle client:load />
            <h1 class="layout__title">{title}</h1>
            <ThemeToggle client:load />
          </header>
          <div class="layout__content">
            <slot />
          </div>
        </main>
      </div>
    </AuthGuard>
  </body>
</html>
